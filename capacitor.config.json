{
  "appId": "com.chan.watchparty",
  "appName": "Chan",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*.vercel.app", "*.firebaseio.com", "*.googleapis.com", "*.gstatic.com", "*.google.com"]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0f"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0f",
      "showSpinner": true,
      "spinnerColor": "#FF6A2B"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
