rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function roomData(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function participantData(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data;
    }

    function isRoomHost(roomId) {
      return isAuthed() && roomData(roomId).hostId == request.auth.uid;
    }

    function isRoomCoHost(roomId) {
      return isAuthed()
        && roomData(roomId).get('coHosts', []).hasAny([request.auth.uid]);
    }

    function isRoomHostOrCoHost(roomId) {
      return isRoomHost(roomId) || isRoomCoHost(roomId);
    }

    function isRoomParticipant(roomId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid));
    }

    function isMuted(roomId) {
      return isRoomParticipant(roomId)
        && participantData(roomId).get('muted', false) == true;
    }

    match /users/{uid} {
      allow read: if isAuthed();
      allow create, update: if isOwner(uid) || isAuthed();
      
      match /stats/{statId} {
        allow read: if isAuthed();
        allow create, update: if isOwner(uid) || isAuthed();
      }

      match /watchLater/{bookmarkId} {
        allow read, write, delete: if isOwner(uid) || isAuthed();
      }
    }

    match /scrapes/{scrapeId} {
      allow read: if isAuthed();
      allow create: if false;
      allow update, delete: if false;
    }

    match /mediaCatalog/{catalogId}/channels/{channelId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow read: if isAuthed();

      allow create: if isAuthed()
        && request.resource.data.hostId == request.auth.uid;

      allow update: if isRoomHostOrCoHost(roomId) || isRoomParticipant(roomId);

      match /playerState/{docId} {
        allow read: if isAuthed() && docId == 'current';
        allow write: if (isRoomHostOrCoHost(roomId) || isAuthed()) && docId == 'current';
      }

      match /queue/{itemId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.addedByUid == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 150;
        allow delete: if isRoomHostOrCoHost(roomId) || (isAuthed() && resource.data.addedByUid == request.auth.uid);
      }

      match /floatingReactions/{reactionId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.emoji is string
          && request.resource.data.emoji.size() <= 16;
      }

      match /soundEffects/{fxId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.soundKey is string;
      }

      match /stagePins/{pinId} {
        allow read: if isAuthed();
        allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
        allow delete: if isRoomHostOrCoHost(roomId) || (isAuthed() && resource.data.uid == request.auth.uid);
      }

      match /quiz/{docId} {
        allow read: if isAuthed();
        allow write: if isAuthed(); // API / users voting or creating room quiz
      }

      match /aiState/{docId} {
        allow read: if isAuthed();
        allow write: if isRoomHostOrCoHost(roomId) || isAuthed();
      }

      match /participants/{uid} {
        allow read: if isAuthed();
        allow write: if false;
      }

      match /messages/{messageId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && isRoomParticipant(roomId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && !isMuted(roomId);

        match /reactions/{uid} {
          allow read: if isAuthed();
          allow create, update: if isOwner(uid)
            && isRoomParticipant(roomId)
            && request.resource.data.emoji is string
            && request.resource.data.emoji.size() > 0
            && request.resource.data.emoji.size() <= 16;
          allow delete: if isOwner(uid);
        }
      }

      match /typing/{uid} {
        allow read: if isAuthed();
        allow create, update: if isOwner(uid) && isRoomParticipant(roomId);
        allow delete: if isOwner(uid);
      }
    }
  }
}
