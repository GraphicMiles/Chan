# Firebase client configuration (required in the browser bundle)
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_APP_ID=replace-with-app-id
VITE_FIREBASE_MEASUREMENT_ID=

# YouTube Data API v3 (restrict this key to your app origins and the YouTube API)
VITE_YOUTUBE_API_KEY=replace-with-restricted-youtube-key

# LiveKit (public URL only in the client)
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Firebase Admin SDK — server-side only; never commit real values
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY=replace-with-escaped-private-key

# LiveKit server-side credentials — never expose these in VITE_ variables
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret

# Optional cron secret
CRON_SECRET=replace-with-random-cron-secret

# Optional server-side search providers
YOUTUBE_API_KEY=replace-with-server-side-youtube-key
OMDB_API_KEY=replace-with-omdb-key
FOOTBALL_DATA_KEY=replace-with-football-data-key

# NSFW provider (disabled by default; requires compliant age/access controls)
NSFW_ENABLED=false
NSFW_PROVIDER=xvideos
# Optional explicit sports-to-IPTV mapping. Channel names are matched against the M3U catalog.
# Example: [{"competition":"Premier League","channels":["SuperSport","Sky Sports"]}]
SPORTS_CHANNEL_MAP_JSON=[]

# IPTV catalog. The default is the Free-TV playlist; override with one or more trusted HTTPS M3U URLs.
IPTV_PLAYLIST_URL=https://raw.githubusercontent.com/Free-TV/IPTV/master/playlist.m3u8
# Optional multi-provider list: [{"id":"free-tv","label":"Free-TV IPTV","url":"https://raw.githubusercontent.com/Free-TV/IPTV/master/playlist.m3u8","enabled":true}]
IPTV_PLAYLISTS_JSON=[]
# Set true after the cron has populated healthy channels in Firestore.
IPTV_USE_FIRESTORE_CATALOG=false
IPTV_HEALTH_CHECK_LIMIT=50
# Optional additional licensed/public channels, as JSON.
IPTV_CHANNELS_JSON=[]
