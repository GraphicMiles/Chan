# Firebase Client (required in client bundle)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# YouTube Data API v3 (required in client bundle, for search / metadata only)
VITE_YOUTUBE_API_KEY=

# LiveKit (public URL only in client; keys stay server-side)
VITE_LIVEKIT_URL=

# Firebase Admin SDK (server-side only, used by Vercel functions in /api)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# LiveKit server-side credentials (used by /api/createLiveKitToken only)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional cron secret (used by /api/cleanupStaleRooms to block unauthorized calls)
CRON_SECRET=
